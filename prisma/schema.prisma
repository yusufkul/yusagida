generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String     @id @default(uuid())
  username     String     @unique
  passwordHash String
  companyName  String
  customers    Customer[]
  products     Product[]
  orders       Order[]
  invoices     Invoice[]
  payments     Payment[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Customer {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  name      String
  email     String?
  phone     String?
  balance   Float     @default(0.0) // Bakiye: Pozitifse borçlu, negatifse alacaklı
  orders    Order[]
  payments  Payment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id             String      @id @default(uuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  name           String
  sku            String?
  minStockAlert  Int         @default(10)
  price          Float       @default(0.0)
  stock          Int         @default(0) // Yeni: Adet bazlı stok
  orderItems     OrderItem[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Order {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id])
  totalAmount Float
  status      String      @default("COMPLETED")
  items       OrderItem[]
  invoices    Invoice[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model Invoice {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  invoiceNumber String
  total         Float
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
}

model Payment {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount     Float
  date       DateTime @default(now())
  createdAt  DateTime @default(now())
}
